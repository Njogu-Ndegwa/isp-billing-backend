{
    "info": {
        "name": "Dual-Mode Ports (PPPoE + Hotspot) - Endpoints",
        "description": "Configure ports to serve both PPPoE and Hotspot on the same interface. Ports stay in the hotspot bridge while a PPPoE server is also bound to that bridge.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8000"
        },
        {
            "key": "routerId",
            "value": "1"
        }
    ],
    "item": [
        {
            "name": "Set Dual-Mode Ports",
            "request": {
                "method": "PUT",
                "url": "{{baseUrl}}/api/routers/{{routerId}}/dual-ports",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\"ports\": [\"ether3\", \"ether4\"]}"
                },
                "description": "Configure which ethernet ports run in dual mode (PPPoE + Hotspot). Ports stay in the hotspot bridge while a PPPoE server is also bound to the bridge. Pass an empty list to remove dual mode and revert to hotspot-only."
            }
        },
        {
            "name": "Clear Dual-Mode Ports",
            "request": {
                "method": "PUT",
                "url": "{{baseUrl}}/api/routers/{{routerId}}/dual-ports",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\"ports\": []}"
                },
                "description": "Remove dual mode from all ports, reverting them to hotspot-only."
            }
        },
        {
            "name": "Get Port Status (includes dual)",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "{{baseUrl}}/api/routers/{{routerId}}/ports",
                    "host": ["{{baseUrl}}"],
                    "path": ["api", "routers", "{{routerId}}", "ports"],
                    "query": [
                        {
                            "key": "refresh",
                            "value": "true",
                            "description": "Force refresh, bypass cache"
                        }
                    ]
                },
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "description": "Get all port statuses. Ports in dual mode will show service='dual'."
            }
        },
        {
            "name": "Get Interfaces (includes dual_ports)",
            "request": {
                "method": "GET",
                "url": "{{baseUrl}}/api/routers/{{routerId}}/interfaces",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "description": "Get available ethernet interfaces with current port assignments including dual_ports."
            }
        },
        {
            "name": "Diagnose Dual Port (full stack + customer)",
            "request": {
                "method": "POST",
                "url": "{{baseUrl}}/api/routers/{{routerId}}/diagnose/dual-port",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"port\": \"ether3\",\n  \"mac_address\": \"AA:BB:CC:DD:EE:FF\",\n  \"customer_id\": 123\n}"
                },
                "description": "Admin-facing diagnostic for the case 'PPPoE works but hotspot says no internet / no Wi-Fi'. Walks the dual-bridge stack (bridge, address, DHCP, hotspot profile/server, NAT, PPPoE, WAN, port link) and — when a MAC or customer_id is supplied — inspects ARP, DHCP lease, hotspot host, ip-binding, active session, queues and the customer's billing state. Every check that the BILLING SYSTEM itself causes is tagged `system_block: true` and surfaced under `system_blocks`, so you can instantly see whether you are blocking the customer's hotspot.\n\nAll body fields are optional — call with no body for an infrastructure-only health check on the dual-mode bridge."
            }
        },
        {
            "name": "Diagnose Dual Port (port only - infra check)",
            "request": {
                "method": "POST",
                "url": "{{baseUrl}}/api/routers/{{routerId}}/diagnose/dual-port",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"port\": \"ether3\"\n}"
                },
                "description": "Run only the infrastructure + physical-link layer diagnostic on a port — no customer/MAC required. Useful when a whole port has no Wi-Fi service."
            }
        },
        {
            "name": "Diagnose Dual Port (customer only)",
            "request": {
                "method": "POST",
                "url": "{{baseUrl}}/api/routers/{{routerId}}/diagnose/dual-port",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"customer_id\": 123\n}"
                },
                "description": "Pull the customer's MAC + plan + status from our DB and run the diagnostic with that context — no port needed."
            }
        }
    ]
}
