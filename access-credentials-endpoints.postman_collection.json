{
    "info": {
        "name": "Access Credentials - Endpoints",
        "description": "Reseller-managed comp hotspot credentials. Resellers create username/password pairs that customers use at the captive portal to come online; one credential = one device at a time, perpetual until revoked.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        { "key": "baseUrl", "value": "http://localhost:8000" },
        { "key": "token", "value": "your-jwt-token-here" }
    ],
    "item": [
        {
            "name": "Reseller Endpoints",
            "item": [
                {
                    "name": "Create Access Credential",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/access-credentials",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"router_id\": 1,\n    \"username\": \"alice\",\n    \"password\": \"s3cret\",\n    \"rate_limit\": \"5M/2M\",\n    \"data_cap_mb\": null,\n    \"label\": \"Front desk laptop\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "description": "Creates a new comp credential. `username` and `password` are optional - server will auto-generate if omitted. `rate_limit` follows MikroTik format (e.g. `5M/2M` = 5 Mbps up / 2 Mbps down). `data_cap_mb` is a lifetime cap; null means unlimited. Returns the credential including the password (so the reseller can hand it to the user)."
                    }
                },
                {
                    "name": "List Access Credentials",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/api/access-credentials?status=active&page=1&per_page=50",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "access-credentials"],
                            "query": [
                                { "key": "status", "value": "active", "description": "Filter: active | revoked | in_use | idle" },
                                { "key": "router_id", "value": "", "disabled": true },
                                { "key": "q", "value": "", "description": "Search by username or label", "disabled": true },
                                { "key": "page", "value": "1" },
                                { "key": "per_page", "value": "50" }
                            ]
                        },
                        "header": [
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "description": "Lists credentials owned by the caller. Each item includes a `live` block (is_online, bound_mac_address, bound_ip_address, current_rx/tx_rate_bps)."
                    }
                },
                {
                    "name": "Get Access Credential (with live usage)",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/api/access-credentials/1?reveal=true",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "access-credentials", "1"],
                            "query": [
                                { "key": "reveal", "value": "true", "description": "Set to true to include the password in the response" }
                            ]
                        },
                        "header": [
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "description": "Returns the credential plus a `live` block fetched from the router (host/queue stats for the bound MAC)."
                    }
                },
                {
                    "name": "Update Access Credential",
                    "request": {
                        "method": "PATCH",
                        "url": "{{baseUrl}}/api/access-credentials/1",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"rate_limit\": \"10M/5M\",\n    \"label\": \"Updated label\",\n    \"data_cap_mb\": 5120,\n    \"clear_rate_limit\": false,\n    \"clear_data_cap\": false,\n    \"clear_label\": false\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "description": "Update rate-limit, data cap, or label. Use the `clear_*` flags to wipe a field. Rate-limit changes are pushed to the router immediately."
                    }
                },
                {
                    "name": "Rotate Password",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/access-credentials/1/rotate-password",
                        "header": [
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "description": "Generates a new password and pushes it to the router. The next /access-login attempt with the old password will fail."
                    }
                },
                {
                    "name": "Revoke Access Credential",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/access-credentials/1/revoke",
                        "header": [
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "description": "Marks the credential as revoked. Removes the hotspot user record, kicks any active session, and clears the bound MAC. Reversible via /restore."
                    }
                },
                {
                    "name": "Restore Access Credential",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/access-credentials/1/restore",
                        "header": [
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "description": "Re-activates a previously revoked credential and re-provisions it on the router. Returns `provisioned: true` on success, or `provisioned: false` with a `warning` string if the router push failed."
                    }
                },
                {
                    "name": "Sync Access Credential (re-push to router)",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/access-credentials/1/sync",
                        "header": [
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "description": "Re-pushes an active credential to its router. Use this after create / rotate-password / update returned `provisioned: false` and you have since fixed the router (brought it online, fixed API user/password/port). Idempotent. 409 if the credential is revoked — call /restore instead."
                    }
                },
                {
                    "name": "Force Logout (free credential)",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/access-credentials/1/force-logout",
                        "header": [
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "description": "Immediately frees the credential by removing the bound device's IP-binding/queue. The user can move to another device or hand the credential off."
                    }
                },
                {
                    "name": "Delete Access Credential",
                    "request": {
                        "method": "DELETE",
                        "url": "{{baseUrl}}/api/access-credentials/1",
                        "header": [
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "description": "Hard-delete. Also removes router-side artifacts. Prefer Revoke unless you really want it gone."
                    }
                }
            ]
        },
        {
            "name": "Public Endpoint",
            "item": [
                {
                    "name": "Access Login (captive portal)",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/public/access-login",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"router_id\": 1,\n    \"username\": \"alice\",\n    \"password\": \"s3cret\",\n    \"mac_address\": \"AA:BB:CC:DD:EE:FF\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "description": "Public endpoint used by the captive portal. Authenticates the credential, enforces single-concurrent-device, and adds a `bypassed` IP-binding for the supplied MAC on the router. 401 = bad credential, 409 = credential currently in use on another MAC, 502 = router not reachable. Returns `{ success, username, rate_limit, mac_address, client_ip }`."
                    }
                }
            ]
        }
    ]
}
